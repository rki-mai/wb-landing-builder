{
    "name": "Draft Service (Go + Mongo)",
    "dockerComposeFile": "../docker-compose.dev.yml",
    "service": "wb-landing-builder",
    "workspaceFolder": "/app",
    "customizations": {
        "vscode": {
            "extensions": [
                "golang.go",
                "ms-azuretools.vscode-docker",
                "mongodb.mongodb-vscode"
            ],
            "settings": {
                "go.useLanguageServer": true,
                "go.gopath": "/go",
                "go.toolsGopath": "/go-tools",
                "files.eol": "\n"
            }
        }
    },
    "forwardPorts": [
        50051,
        2345
    ],
    "postCreateCommand": "go mod download && go install github.com/go-delve/delve/cmd/dlv@latest",
    "remoteUser": "root"
}