{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Element Operations Schema",
    "description": "Schema for validating element operations (create, update, delete, revert) and element structures",
    "definitions": {
        "styles": {
            "type": "object",
            "description": "CSS styles as key-value pairs",
            "patternProperties": {
                "^[a-zA-Z-]+$": {
                    "type": "string",
                    "description": "Any valid CSS property value"
                }
            },
            "additionalProperties": true,
            "minProperties": 0,
            "maxProperties": 100
        },
        "baseElement": {
            "type": "object",
            "required": [
                "element",
                "id"
            ],
            "properties": {
                "id": {
                    "type": "string",
                    "pattern": "^lb-.*$",
                    "description": "Element ID in format lb-N"
                },
                "styles": {
                    "$ref": "#/definitions/styles"
                }
            },
            "additionalProperties": false
        },
        "textElement": {
            "allOf": [
                {
                    "$ref": "#/definitions/baseElement"
                },
                {
                    "properties": {
                        "element": {
                            "type": "string",
                            "const": "text",
                            "description": "Paragraph element"
                        },
                        "value": {
                            "type": "string",
                            "minLength": 1,
                            "maxLength": 50000,
                            "description": "Paragraph text content"
                        }
                    },
                    "required": [
                        "value"
                    ]
                }
            ]
        },
        "containerElement": {
            "allOf": [
                {
                    "$ref": "#/definitions/baseElement"
                },
                {
                    "properties": {
                        "element": {
                            "type": "string",
                            "const": "container",
                            "description": "Container element"
                        }
                    },
                    "required": []
                }
            ]
        },
        "linkElement": {
            "allOf": [
                {
                    "$ref": "#/definitions/baseElement"
                },
                {
                    "properties": {
                        "element": {
                            "type": "string",
                            "const": "link",
                            "description": "Link element"
                        },
                        "value": {
                            "type": "string",
                            "minLength": 1,
                            "maxLength": 1000,
                            "description": "Link text"
                        },
                        "src": {
                            "type": "string",
                            "format": "uri",
                            "minLength": 1,
                            "maxLength": 2000,
                            "description": "Link URL"
                        }
                    },
                    "required": [
                        "value",
                        "src"
                    ]
                }
            ]
        },
        "imageElement": {
            "allOf": [
                {
                    "$ref": "#/definitions/baseElement"
                },
                {
                    "properties": {
                        "element": {
                            "type": "string",
                            "const": "image",
                            "description": "Image element"
                        },
                        "value": {
                            "type": "string",
                            "format": "uri",
                            "minLength": 1,
                            "maxLength": 2000,
                            "description": "Image URL"
                        },
                        "alt": {
                            "type": "string",
                            "maxLength": 500,
                            "description": "Alternative text for image"
                        }
                    },
                    "required": [
                        "value"
                    ]
                }
            ]
        },
        "buttonElement": {
            "allOf": [
                {
                    "$ref": "#/definitions/baseElement"
                },
                {
                    "properties": {
                        "element": {
                            "type": "string",
                            "const": "button",
                            "description": "Button element"
                        },
                        "value": {
                            "type": "string",
                            "minLength": 1,
                            "maxLength": 500,
                            "description": "Button text"
                        },
                        "src": {
                            "type": "string",
                            "format": "uri",
                            "minLength": 1,
                            "maxLength": 2000,
                            "description": "Button link URL"
                        }
                    },
                    "required": [
                        "value",
                        "src"
                    ]
                }
            ]
        },
        "anyElement": {
            "oneOf": [
                {
                    "$ref": "#/definitions/textElement"
                },
                {
                    "$ref": "#/definitions/containerElement"
                },
                {
                    "$ref": "#/definitions/linkElement"
                },
                {
                    "$ref": "#/definitions/imageElement"
                },
                {
                    "$ref": "#/definitions/buttonElement"
                }
            ]
        },
        "createData": {
            "type": "object",
            "required": [
                "element",
                "parentId",
                "id",
                "index"
            ],
            "properties": {
                "element": {
                    "type": "string",
                    "enum": [
                        "text",
                        "container",
                        "link",
                        "image",
                        "button"
                    ]
                },
                "value": {
                    "type": "string",
                    "description": "Content for elements that support it"
                },
                "styles": {
                    "$ref": "#/definitions/styles"
                },
                "parentId": {
                    "type": "string",
                    "pattern": "^(root|lb-.*)$",
                    "description": "Parent element ID or 'root' for top-level placement"
                },
                "index": {
                    "type": "integer",
                    "minimum": 0,
                    "description": "Position index among siblings"
                },
                "src": {
                    "type": "string",
                    "format": "uri",
                    "description": "URL for link/button/image elements"
                },
                "alt": {
                    "type": "string",
                    "description": "Alternative text for image elements"
                },
                "id": {
                    "type": "string",
                    "pattern": "^lb-.*$",
                    "description": "Optional ID for new element (server usually generates)"
                }
            },
            "additionalProperties": false,
            "allOf": [
                {
                    "if": {
                        "properties": {
                            "element": {
                                "const": "container"
                            }
                        }
                    },
                    "then": {
                        "properties": {
                            "value": false,
                            "src": false,
                            "alt": false
                        }
                    }
                },
                {
                    "if": {
                        "properties": {
                            "element": {
                                "const": "image"
                            }
                        }
                    },
                    "then": {
                        "required": [
                            "value"
                        ],
                        "properties": {
                            "src": false
                        }
                    }
                },
                {
                    "if": {
                        "properties": {
                            "element": {
                                "const": "link"
                            }
                        }
                    },
                    "then": {
                        "required": [
                            "value",
                            "src"
                        ]
                    }
                },
                {
                    "if": {
                        "properties": {
                            "element": {
                                "const": "button"
                            }
                        }
                    },
                    "then": {
                        "required": [
                            "value",
                            "src"
                        ]
                    }
                },
                {
                    "if": {
                        "properties": {
                            "element": {
                                "const": "text"
                            }
                        }
                    },
                    "then": {
                        "required": [
                            "value"
                        ]
                    }
                }
            ]
        },
        "fieldsUpdate": {
            "type": "object",
            "description": "Partial update fields",
            "properties": {
                "value": {
                    "type": "string",
                    "description": "Update content value"
                },
                "styles": {
                    "$ref": "#/definitions/styles",
                    "description": "Update styles (merged with existing)"
                },
                "parentId": {
                    "type": "string",
                    "pattern": "^(root|lb-.*)$",
                    "description": "Move to new parent"
                },
                "index": {
                    "type": "integer",
                    "minimum": 0,
                    "description": "Update position"
                },
                "src": {
                    "type": "string",
                    "format": "uri",
                    "description": "Update URL"
                },
                "alt": {
                    "type": "string",
                    "description": "Update alt text"
                }
            },
            "minProperties": 1,
            "additionalProperties": false
        },
        "updateData": {
            "type": "object",
            "required": [
                "id",
                "fields"
            ],
            "properties": {
                "id": {
                    "type": "string",
                    "pattern": "^lb-.*$",
                    "description": "ID of element to update"
                },
                "fields": {
                    "$ref": "#/definitions/fieldsUpdate"
                }
            },
            "additionalProperties": false
        },
        "deleteData": {
            "type": "object",
            "required": [
                "id"
            ],
            "properties": {
                "id": {
                    "type": "string",
                    "pattern": "^lb-.*$",
                    "description": "ID of element to delete (cascading)"
                }
            },
            "additionalProperties": false
        },
        "revertData": {
            "type": "object",
            "required": [
                "count"
            ],
            "properties": {
                "count": {
                    "type": "integer",
                    "minimum": 1,
                    "description": "Number of following mutations to remove from effective history"
                }
            },
            "additionalProperties": false
        }
    },
    "type": "object",
    "required": [
        "operation",
        "data"
    ],
    "properties": {
        "operation": {
            "type": "string",
            "enum": [
                "create",
                "update",
                "delete",
                "revert"
            ],
            "description": "Operation type to perform"
        },
        "data": {
            "type": "object",
            "description": "Operation-specific data"
        }
    },
    "additionalProperties": false,
    "allOf": [
        {
            "if": {
                "properties": {
                    "operation": {
                        "const": "create"
                    }
                }
            },
            "then": {
                "properties": {
                    "data": {
                        "$ref": "#/definitions/createData"
                    }
                }
            }
        },
        {
            "if": {
                "properties": {
                    "operation": {
                        "const": "update"
                    }
                }
            },
            "then": {
                "properties": {
                    "data": {
                        "$ref": "#/definitions/updateData"
                    }
                }
            }
        },
        {
            "if": {
                "properties": {
                    "operation": {
                        "const": "delete"
                    }
                }
            },
            "then": {
                "properties": {
                    "data": {
                        "$ref": "#/definitions/deleteData"
                    }
                }
            }
        },
        {
            "if": {
                "properties": {
                    "operation": {
                        "const": "revert"
                    }
                }
            },
            "then": {
                "properties": {
                    "data": {
                        "$ref": "#/definitions/revertData"
                    }
                }
            }
        }
    ]
}