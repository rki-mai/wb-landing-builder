# Server Configuration
SERVER_URL=http://localhost
PORT=8080
ENVIRONMENT=production
LOG_LEVEL=info
READ_TIMEOUT=10s
WRITE_TIMEOUT=10s
RATE_LIMIT=100

# API Security
API_SECRET=stub

# MongoDB Configuration
MONGO_HOST=mongo
MONGO_PORT=27017
MONGO_USER=admin
MONGO_PASSWORD=admin
MONGO_DATABASE=storage
MONGO_MAX_CONNECTIONS=100
MONGO_TTL_DAYS=30

# JWT Configuration
JWT_SECRET=super-secret-key
JWT_EXPIRATION=15m

# Refresh Token
REFRESH_TOKEN_EXPIRATION=168h